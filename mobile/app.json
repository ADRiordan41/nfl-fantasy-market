{
  "expo": {
    "name": "MatchupMarket",
    "slug": "matchupmarket",
    "scheme": "matchupmarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matchupmarket.app"
    },
    "android": {
      "package": "com.matchupmarket.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

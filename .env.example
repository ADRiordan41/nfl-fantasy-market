DATABASE_URL=postgresql+psycopg://fantasy:fantasy@db:5432/fantasy_market
STARTING_CASH=100000
DEFAULT_PRIMARY_SPORT=NFL
SEASON_WEEKS=18
PERFORMANCE_WEIGHT=1.0
SEASON_CLOSE_PAYOUT_PER_POINT=1.0
MIN_SPOT_PRICE=1.0
MAINTENANCE_MARGIN_LONG=0.0
MAINTENANCE_MARGIN_SHORT=0.0
MAX_POSITION_NOTIONAL_PER_PLAYER=10000
OPEN_POSITION_FEE_RATE=0.0
PRICE_IMPACT_MULTIPLIER=0.2
MARKET_REVERSION_HALF_LIFE_MINUTES=180
BASE_SPREAD_PCT=0.012
LIVE_SPREAD_MULTIPLIER=1.35
VOLATILITY_SPREAD_MULTIPLIER=0.35
MAX_TOTAL_SPREAD_PCT=0.08
LIQUIDITY_REFERENCE_PRICE=180
MIN_LIQUIDITY_MULTIPLIER=0.75
MAX_LIQUIDITY_MULTIPLIER=1.85
LIVE_IMPACT_MULTIPLIER=1.2
RECENT_FORM_WINDOW=3
RECENT_FORM_WEIGHT=0.22
LIVE_POINTS_WEIGHT=1.0
MIN_PROJECTED_WEIGHT=0.18
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_TTL_HOURS=168
ADMIN_USERNAMES=foreverhopeful
# Rate limits (writes/auth). Tune for beta traffic.
RATE_LIMIT_AUTH_LOGIN=12
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_AUTH_REGISTER=6
RATE_LIMIT_AUTH_REGISTER_WINDOW_SECONDS=3600
REGISTER_MIN_SUBMIT_MS=2500
RATE_LIMIT_AUTH_PASSWORD_RESET_REQUEST=6
RATE_LIMIT_AUTH_PASSWORD_RESET_REQUEST_WINDOW_SECONDS=3600
RATE_LIMIT_AUTH_PASSWORD_RESET_CONFIRM=12
RATE_LIMIT_AUTH_PASSWORD_RESET_CONFIRM_WINDOW_SECONDS=1800
PASSWORD_RESET_TTL_MINUTES=60
PASSWORD_RESET_PREVIEW_ENABLED=false
PASSWORD_RESET_BASE_URL=http://localhost:3000/auth
RATE_LIMIT_FORUM_POST_CREATE=8
RATE_LIMIT_FORUM_POST_CREATE_WINDOW_SECONDS=600
RATE_LIMIT_FORUM_COMMENT_CREATE=30
RATE_LIMIT_FORUM_COMMENT_CREATE_WINDOW_SECONDS=600
RATE_LIMIT_MODERATION_REPORT_CREATE=20
RATE_LIMIT_MODERATION_REPORT_CREATE_WINDOW_SECONDS=3600
# Optional: pepper used when hashing bearer tokens at rest.
# SESSION_TOKEN_PEPPER=replace-with-random-secret
# Optional bootstrap username/password for sandbox account.
# SANDBOX_USERNAME=ForeverHopeful
# SANDBOX_PASSWORD=sandbox
# Optional roster/projection overrides:
# By default, seeding loads `backend/data/nfl_*` and also `backend/data/mlb_*` when MLB files exist.
# PLAYER_CSV_PATHS=/app/data/nfl_players.csv,/app/data/mlb_players.csv
# PLAYER_PROJECTIONS_CSV_PATHS=/app/data/nfl_projections_2026.csv,/app/data/mlb_projections_2026.csv
# Backward-compatible single-path overrides:
# PLAYER_CSV_PATH=/absolute/path/to/nfl_players.csv
# PLAYER_PROJECTIONS_CSV_PATH=/absolute/path/to/nfl_projections_2026.csv
# REQUIRE_PROJECTIONS=true
# SEED_UPDATE_EXISTING_PRICING=true
